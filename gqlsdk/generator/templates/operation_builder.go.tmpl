{{- /* Operation Builder template */ -}}

// {{ .BuilderName }} builds a {{ .OpType }} for {{ .FieldName }}
type {{ .BuilderName }} struct {
{{- if .RootPkg }}
	*{{ .RootPkg }}.BaseBuilder
{{- else }}
	*BaseBuilder
{{- end }}
}

{{- range .Arguments }}
// {{ .MethodName }} sets the {{ .ArgName }} argument
func (b *{{ $.BuilderName }}) {{ .MethodName }}(v {{ .GoType }}) *{{ $.BuilderName }} {
	b.SetArg("{{ .ArgName }}", v, "{{ .GraphQLType }}")
	return b
}
{{- end }}

{{- if .HasSelect }}
// Select configures which fields to return
{{- if .FieldsPkg }}
func (b *{{ .BuilderName }}) Select(selector func(*{{ .FieldsPkg }}.{{ .SelectorName }})) *{{ .BuilderName }} {
	selector({{ .FieldsPkg }}.New{{ .SelectorName }}(b.GetSelection()))
	return b
}
{{- else }}
func (b *{{ .BuilderName }}) Select(selector func(*{{ .SelectorName }})) *{{ .BuilderName }} {
	selector(New{{ .SelectorName }}(b.GetSelection()))
	return b
}
{{- end }}
{{- end }}

// Execute runs the {{ .OpType }} and returns the result
func (b *{{ .BuilderName }}) Execute(ctx context.Context) ({{ .ReturnType }}, error) {
	query := b.BuildQuery()
	variables := b.GetVariables()

	var response struct {
		Data struct {
			Result {{ .ReturnType }} `json:"{{ .FieldName }}"`
		} `json:"data"`
	}

	if err := b.GetClient().Execute(ctx, query, variables, &response); err != nil {
		return {{ .ZeroValue }}, err
	}

	return response.Data.Result, nil
}
